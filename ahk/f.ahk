#y::  ; Win + Y
    SendMode, Input

    Send, ^l          ; Ctrl+L
    Send, ^c          ; Ctrl+C
    Send, #t          ; Win+T
    Send, ^t          ; Ctrl+T
    SendRaw, y        ; y
    Send, {Space}     ; space
    Send, ^v          ; Ctrl+V
    Send, {Enter}
    Send, !{Tab}      ; Alt+Tab
return

